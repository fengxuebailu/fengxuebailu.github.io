---
import { getCollection } from "astro:content";
import SectionRow from "./SectionRow.astro";

type LinkKind = "pdf" | "code" | "arxiv" | "project";

const pubs = (await getCollection("publications")).sort((a, b) => {
  const ao = a.data.order ?? Number(a.data.year);
  const bo = b.data.order ?? Number(b.data.year);
  return bo - ao;
});

const linkLabels: Record<LinkKind, string> = {
  pdf: "PDF",
  code: "Code",
  arxiv: "arXiv",
  project: "Project",
};

/** Highlight my own name (author entry that ends with "*"). */
function renderAuthors(raw: string): string {
  if (!raw) return "";
  return raw
    .split(",")
    .map((name) => {
      const trimmed = name.trim();
      if (trimmed.endsWith("*")) {
        const bare = trimmed.slice(0, -1);
        return `<span class="font-medium" style="color:var(--fg);">${bare}</span>`;
      }
      return trimmed;
    })
    .join(", ");
}
---

<section id="publications" class="fade-in">
  <h2 class="section-h2 mb-6">Publications</h2>
  <ol class="space-y-1">
    {
      pubs.map((p) => {
        const links: { kind: LinkKind; href: string }[] = (
          ["pdf", "code", "arxiv", "project"] as LinkKind[]
        ).map((k) => ({ kind: k, href: (p.data[k] as string) ?? "" }));
        const isPlaceholder = p.data.placeholder;

        return (
          <li>
            <SectionRow date={String(p.data.year)}>
              <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
                <h3
                  class:list={[
                    "leading-snug text-[15px]",
                    isPlaceholder ? "italic" : "font-medium",
                  ]}
                  style={`color: ${isPlaceholder ? "var(--fg-faint)" : "var(--fg)"};`}
                >
                  {p.data.title}
                </h3>
                {p.data.status && (
                  <span
                    class="italic text-[13px] tracking-wide"
                    style="color: var(--fg-subtle);"
                  >
                    {p.data.status}
                  </span>
                )}
              </div>
              {!isPlaceholder && p.data.authors && (
                <p
                  class="mt-0.5 text-[14px] leading-snug"
                  style="color: var(--fg-muted);"
                  set:html={renderAuthors(p.data.authors)}
                />
              )}
              {!isPlaceholder && p.data.venue && (
                <p
                  class="mt-0.5 text-[14px] leading-snug italic"
                  style="color: var(--fg-muted);"
                >
                  {p.data.venue}
                </p>
              )}
              {links.some((l) => l.href.length > 0) && (
                <p class="mt-1 text-[13px]">
                  {links
                    .filter((l) => l.href.length > 0)
                    .map((l, i) => (
                      <>
                        {i > 0 && (
                          <span style="color: var(--fg-subtle);"> · </span>
                        )}
                        <a
                          href={l.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="link-underline"
                        >
                          {linkLabels[l.kind]}
                        </a>
                      </>
                    ))}
                </p>
              )}
            </SectionRow>
          </li>
        );
      })
    }
  </ol>
</section>
