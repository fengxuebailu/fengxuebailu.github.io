---
import { getCollection } from "astro:content";
import PubThumb from "./PubThumb.astro";

/**
 * Selected Publications — al-folio shape.
 *   [thumb 9rem] [title / authors / venue / link chips]
 *
 * Self-author marked with trailing "*" gets bolded via .me class.
 */

type LinkKind = "pdf" | "code" | "arxiv" | "project";

const pubs = (await getCollection("publications")).sort((a, b) => {
  const ao = a.data.order ?? Number(a.data.year);
  const bo = b.data.order ?? Number(b.data.year);
  return bo - ao;
});

const linkLabels: Record<LinkKind, string> = {
  pdf: "PDF",
  code: "code",
  arxiv: "arXiv",
  project: "project",
};

function renderAuthors(raw: string): string {
  if (!raw) return "";
  return raw
    .split(",")
    .map((name) => {
      const t = name.trim();
      if (t.endsWith("*")) return `<span class="me">${t.slice(0, -1)}</span>`;
      return t;
    })
    .join(", ");
}

const baseUrl = import.meta.env.BASE_URL;
---

<section id="publications" class="fade-in mt-16">
  <h2 class="section-h2">selected publications</h2>
  <div role="list">
    {pubs.map((p) => {
      const links: { kind: LinkKind; href: string }[] = (
        ["pdf", "code", "arxiv", "project"] as LinkKind[]
      )
        .map((k) => ({ kind: k, href: (p.data[k] as string) ?? "" }))
        .filter((l) => l.href.length > 0);
      const isPlaceholder = p.data.placeholder;
      const titleClass = isPlaceholder ? "pub-title italic" : "pub-title";
      return (
        <article role="listitem" class="pub-item">
          <div class="pub-thumb" aria-hidden="true">
            {p.data.thumb ? (
              <img src={`${baseUrl}${p.data.thumb}`} alt="" />
            ) : (
              <PubThumb />
            )}
          </div>
          <div class="min-w-0">
            <h3 class={titleClass} style={isPlaceholder ? "color: var(--fg-muted);" : undefined}>
              {p.data.title}
              {p.data.status && <span class="pub-status">{p.data.status}</span>}
            </h3>
            {p.data.authors && (
              <p class="pub-authors" set:html={renderAuthors(p.data.authors)} />
            )}
            {p.data.venue && (
              <p class="pub-venue">
                {p.data.venue}
                {p.data.year && <span> · {p.data.year}</span>}
              </p>
            )}
            {!p.data.venue && p.data.year && (
              <p class="pub-venue">{p.data.year}</p>
            )}
            {links.length > 0 && (
              <p class="pub-links">
                {links.map((l) => (
                  <a class="pub-link-chip" href={l.href} target="_blank" rel="noopener noreferrer">
                    {linkLabels[l.kind]}
                  </a>
                ))}
              </p>
            )}
          </div>
        </article>
      );
    })}
  </div>
</section>
