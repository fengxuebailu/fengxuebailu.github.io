---
import { site } from "../data/site";
import Section from "./Section.astro";
---

<Section
  id="research"
  title="Research Interests"
  subtitle="What I'm working on, broadly."
>
  <ul class="flex flex-wrap gap-2 fade-up">
    {
      site.researchInterests.map((tag) => (
        <li>
          <span
            class="inline-flex items-center rounded-full border border-zinc-200 bg-white px-3 py-1 text-sm text-zinc-700 transition hover:-translate-y-0.5 hover:border-emerald-500/40 hover:bg-emerald-50/60 hover:text-emerald-700 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-emerald-400/40 dark:hover:bg-emerald-950/40 dark:hover:text-emerald-300"
          >
            {tag}
          </span>
        </li>
      ))
    }
  </ul>
</Section>
