---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200/70 dark:border-zinc-800/70">
  <div
    class="mx-auto flex max-w-3xl flex-col items-start justify-between gap-2 px-6 py-8 text-xs text-zinc-500 sm:flex-row sm:items-center dark:text-zinc-400"
  >
    <span>
      © {year} {site.name.enFull}. Built with
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="prose-link hover:text-emerald-600 dark:hover:text-emerald-400"
        >Astro</a
      >
      &amp; Tailwind.
    </span>
    <a
      href="#about"
      class="prose-link hover:text-emerald-600 dark:hover:text-emerald-400"
      >Back to top ↑</a
    >
  </div>
</footer>
