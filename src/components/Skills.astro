---
import { getCollection } from "astro:content";

const items = (await getCollection("skills")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
);
---

<section id="skills" class="fade-in">
  <h2 class="section-h2 mb-6">Skills</h2>
  <dl class="space-y-1">
    {
      items.map((it) => (
        <div class="tl-row grid grid-cols-1 sm:grid-cols-[7.5rem_1fr] gap-x-6 gap-y-1 items-baseline">
          <dt
            class="text-[13.5px] tabular-nums"
            style="color: var(--fg-subtle);"
          >
            {it.data.category}
          </dt>
          <dd class="text-[15px]" style="color: var(--fg);">
            {it.data.items.join("  ·  ")}
          </dd>
        </div>
      ))
    }
  </dl>
</section>
