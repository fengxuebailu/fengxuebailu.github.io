---
import { site } from "../data/site";
const githubHandle = site.github.replace(/^https?:\/\/github\.com\//, "");
---

<section id="projects" class="fade-in">
  <h2 class="section-h2 mb-6">Selected Projects</h2>
  <p class="text-[15px] leading-7" style="color: var(--fg-muted);">
    Selected projects will be added as they mature. Current explorations live on
    <a
      href={site.github}
      target="_blank"
      rel="noopener noreferrer"
      class="link-underline"
      style="color: var(--fg);"
    >github.com/{githubHandle}</a>.
  </p>
</section>
