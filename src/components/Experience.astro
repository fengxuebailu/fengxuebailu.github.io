---
import { getCollection } from "astro:content";
import SectionRow from "./SectionRow.astro";

const items = (await getCollection("experience")).sort(
  (a, b) => (b.data.order ?? 0) - (a.data.order ?? 0),
);

const allPlaceholder = items.length === 0 || items.every((i) => i.data.placeholder);
---

<section id="experience" class="fade-in">
  <h2 class="section-h2 mb-6">Experience</h2>

  {allPlaceholder ? (
    <p class="muted-italic text-[14px] leading-7">
      Lab rotations and internships will appear here as they happen.
    </p>
  ) : (
    <ol class="space-y-1">
      {items.filter((i) => !i.data.placeholder).map((item) => (
        <li>
          <SectionRow date={item.data.period} sub={item.data.location}>
            <div class="font-medium leading-snug" style="color: var(--fg);">
              {item.data.title}
              {item.data.org && (
                <span style="color: var(--fg-muted);"> · {item.data.org}</span>
              )}
            </div>
            {item.data.description && (
              <p
                class="text-[14px] mt-1 leading-relaxed"
                style="color: var(--fg-muted);"
              >
                {item.data.description}
              </p>
            )}
          </SectionRow>
        </li>
      ))}
    </ol>
  )}
</section>
