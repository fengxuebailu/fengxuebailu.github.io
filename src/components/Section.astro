---
interface Props {
  id: string;
  title: string;
  subtitle?: string;
  /** When true, no top border (used for first section after Hero). */
  flush?: boolean;
}
const { id, title, subtitle, flush = false } = Astro.props;
---

<section
  id={id}
  class:list={[
    "py-16 md:py-20",
    !flush && "border-t border-zinc-200/70 dark:border-zinc-800/70",
  ]}
>
  <div class="mx-auto max-w-3xl px-6">
    <header class="mb-8 fade-up">
      <h2
        class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50"
      >
        {title}
      </h2>
      {
        subtitle && (
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
            {subtitle}
          </p>
        )
      }
    </header>
    <slot />
  </div>
</section>
