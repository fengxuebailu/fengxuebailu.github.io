---
/**
 * Two-column timeline row used by Education / Experience / Publications.
 * Left column: date / period (mono, tabular-nums, muted).
 * Right column: free slot for title + meta lines.
 *
 * On <640px the row collapses to single column.
 */
interface Props {
  /** Left-column text. e.g. "2023.09 — Now" or "2026". */
  date: string;
  /** Optional sub-line under the date (location etc.). */
  sub?: string;
}
const { date, sub } = Astro.props;
---

<div class="tl-row grid grid-cols-1 sm:grid-cols-[7.5rem_1fr] gap-x-6 gap-y-1 items-baseline">
  <div class="text-[13.5px] tabular-nums" style="color: var(--fg-subtle);">
    <div>{date}</div>
    {sub && (
      <div class="text-[12.5px] mt-0.5" style="color: var(--fg-faint);">
        {sub}
      </div>
    )}
  </div>
  <div class="text-[15px]" style="color: var(--fg);">
    <slot />
  </div>
</div>
