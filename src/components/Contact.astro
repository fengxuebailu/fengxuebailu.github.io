---
import Section from "./Section.astro";
import { site } from "../data/site";

type IconKey = "mail" | "github" | "graduation-cap" | "book-open";
const iconPaths: Record<IconKey, string> = {
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  github:
    '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  "graduation-cap":
    '<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/>',
  "book-open":
    '<path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>',
};

const items: { label: string; href: string; icon: IconKey }[] = [
  { label: site.email, href: `mailto:${site.email}`, icon: "mail" },
  { label: "GitHub", href: site.github, icon: "github" },
];
if (site.scholar)
  items.push({ label: "Google Scholar", href: site.scholar, icon: "graduation-cap" });
if (site.orcid)
  items.push({ label: "ORCID", href: site.orcid, icon: "book-open" });
---

<Section id="contact" title="Contact">
  <p
    class="mb-5 text-[15px] leading-7 text-zinc-700 dark:text-zinc-300 fade-up"
  >
    Best reached by email — feel free to drop a note about research, internships,
    or collaboration.
  </p>
  <ul class="flex flex-wrap items-center gap-3 fade-up">
    {
      items.map((it) => (
        <li>
          <a
            href={it.href}
            target={it.href.startsWith("http") ? "_blank" : undefined}
            rel={it.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="inline-flex items-center gap-2 rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm text-zinc-700 transition hover:border-emerald-500/40 hover:text-emerald-700 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-emerald-400/40 dark:hover:text-emerald-400"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={iconPaths[it.icon]}
            />
            <span class="font-mono text-xs">{it.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</Section>
