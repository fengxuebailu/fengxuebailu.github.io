---
/**
 * Sidebar — sticky left column on desktop, top stack on mobile.
 * Contains: name + pinyin + tagline / Research interests / Contact / Last updated.
 * Keeps scope tight: nothing here that doesn't belong on a printed CV header.
 */
import { site } from "../data/site";

const githubHandle = site.github.replace(/^https?:\/\/github\.com\//, "");
---

<aside
  class="lg:sticky lg:top-12 lg:self-start space-y-8"
  aria-label="Profile"
>
  <!-- Name block -->
  <div class="fade-in">
    <h1
      class="flex items-center gap-2 text-[30px] font-semibold leading-[1.15] tracking-tight"
      style="color: var(--fg);"
    >
      <span lang="zh-Hans">{site.name.zh}</span>
      <span
        class="spike"
        title="Spiking like a neuron — research signature"
        aria-hidden="true"></span>
    </h1>
    <p
      class="mt-1 text-[14px] tracking-wide"
      style="color: var(--fg-subtle); letter-spacing: 0.02em;"
    >
      {site.name.enFull}
    </p>

    <p
      class="mt-3 text-[14px] leading-6"
      style="color: var(--fg-muted);"
    >
      {site.tagline}
    </p>
    <p
      class="mt-1.5 text-[14px] leading-6"
      style="color: var(--fg-muted);"
      set:html={site.taglineSecondary}
    />
  </div>

  <!-- Research interests -->
  <div class="fade-in">
    <h2 class="eyebrow mb-3">Research</h2>
    <ul class="space-y-1.5 text-[14px]" style="color: var(--fg);">
      {site.researchInterests.map((r) => <li>{r}</li>)}
    </ul>
  </div>

  <!-- Contact -->
  <div class="fade-in">
    <h2 class="eyebrow mb-3">Contact</h2>
    <ul class="space-y-2 text-[14px]">
      <li>
        <a
          href={`mailto:${site.email}`}
          class="link inline-flex items-center gap-2"
          style="color: var(--fg);"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          <span class="break-all">{site.email}</span>
        </a>
      </li>
      <li>
        <a
          href={site.github}
          target="_blank"
          rel="noopener noreferrer"
          class="link inline-flex items-center gap-2"
          style="color: var(--fg);"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
          <span>github.com/{githubHandle}</span>
        </a>
      </li>
      {site.scholar && (
        <li>
          <a
            href={site.scholar}
            target="_blank"
            rel="noopener noreferrer"
            class="link inline-flex items-center gap-2"
            style="color: var(--fg);"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" />
              <path d="M22 10v6" />
              <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5" />
            </svg>
            <span>Google Scholar</span>
          </a>
        </li>
      )}
      {!site.scholar && (
        <li class="muted-italic flex items-center gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" />
            <path d="M22 10v6" />
            <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5" />
          </svg>
          <span>Scholar (coming soon)</span>
        </li>
      )}
    </ul>
  </div>

  <!-- Last updated -->
  <p class="text-[12px]" style="color: var(--fg-faint);">
    Last updated · {site.lastUpdated}
  </p>
</aside>
