---
import { getCollection } from "astro:content";
import SectionRow from "./SectionRow.astro";

const items = (await getCollection("education")).sort(
  (a, b) => (b.data.order ?? 0) - (a.data.order ?? 0),
);
---

<section id="education" class="fade-in">
  <h2 class="section-h2 mb-6">Education</h2>
  <ol class="space-y-1">
    {
      items.map((item) => (
        <li>
          <SectionRow date={item.data.period} sub={item.data.location}>
            <div class="font-medium leading-snug" style="color: var(--fg);">
              {item.data.school}
            </div>
            <div
              class="text-[14px] mt-0.5 leading-snug"
              style="color: var(--fg-muted);"
            >
              {item.data.degree}
              {item.data.department && <span> · {item.data.department}</span>}
            </div>
            {item.data.notes && item.data.notes.length > 0 && (
              <ul
                class="mt-1 space-y-0.5 text-[13.5px]"
                style="color: var(--fg-subtle);"
              >
                {item.data.notes.map((n) => (
                  <li>— {n}</li>
                ))}
              </ul>
            )}
          </SectionRow>
        </li>
      ))
    }
  </ol>
</section>
