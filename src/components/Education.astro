---
import { getCollection } from "astro:content";
import Section from "./Section.astro";

const items = (await getCollection("education")).sort(
  (a, b) => (b.data.order ?? 0) - (a.data.order ?? 0),
);
---

<Section id="education" title="Education">
  <ol class="space-y-6 fade-stagger">
    {
      items.map((item) => (
        <li class="relative pl-6">
          <span class="absolute left-0 top-2 h-2 w-2 rounded-full bg-emerald-500 ring-4 ring-emerald-500/15" />
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-50">
              {item.data.school}
              {item.data.schoolZh && (
                <span class="ml-1 font-normal text-zinc-500 dark:text-zinc-400">
                  · {item.data.schoolZh}
                </span>
              )}
            </h3>
            <span class="font-mono text-xs text-zinc-500 dark:text-zinc-400">
              {item.data.period}
            </span>
          </div>
          <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
            {item.data.degree}
            {item.data.department && <span> · {item.data.department}</span>}
            {item.data.location && <span> · {item.data.location}</span>}
          </p>
          {item.data.notes && item.data.notes.length > 0 && (
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-zinc-600 dark:text-zinc-400 marker:text-zinc-400 dark:marker:text-zinc-600">
              {item.data.notes.map((n) => (
                <li>{n}</li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ol>
</Section>
