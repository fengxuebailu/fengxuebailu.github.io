---
import { site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";

const initials = site.avatarInitials || site.name.enFull.slice(0, 2);

// Map social icon names to inline SVG paths so we don't need a runtime lib.
const iconPaths: Record<string, string> = {
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  github:
    '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  "graduation-cap":
    '<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/>',
  "book-open":
    '<path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>',
  "external-link":
    '<path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>',
};
---

<header class="relative">
  <!-- Top utility bar with theme toggle -->
  <div class="absolute right-6 top-6 z-10">
    <ThemeToggle />
  </div>

  <div class="mx-auto max-w-3xl px-6 pt-24 pb-12 md:pt-32 md:pb-16">
    <div class="flex flex-col items-start gap-8 sm:flex-row sm:items-center">
      <!-- Avatar / gradient block -->
      <div
        class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-700 text-2xl font-semibold text-white shadow-sm ring-1 ring-emerald-600/20 sm:h-24 sm:w-24 fade-up"
        aria-hidden="true"
      >
        {initials}
      </div>

      <div class="fade-up">
        <h1
          class="text-4xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-5xl md:text-6xl"
        >
          {site.name.zh}
        </h1>
        <p
          class="mt-2 text-base font-medium tracking-wide text-zinc-500 dark:text-zinc-400"
        >
          {site.name.enFull}
        </p>
      </div>
    </div>

    <p
      class="mt-8 max-w-prose text-[15px] leading-7 text-zinc-700 dark:text-zinc-300 fade-up"
    >
      {site.tagline}
    </p>

    <!-- Social row -->
    <ul class="mt-8 flex items-center gap-2 fade-up" aria-label="Social links">
      {
        site.social.map((s) => (
          <li>
            <a
              href={s.href}
              aria-label={s.label}
              title={s.label}
              class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-zinc-200 bg-white/60 text-zinc-600 transition hover:border-emerald-500/50 hover:text-emerald-600 dark:border-zinc-800 dark:bg-zinc-900/60 dark:text-zinc-400 dark:hover:border-emerald-400/50 dark:hover:text-emerald-400"
              target={s.href.startsWith("http") ? "_blank" : undefined}
              rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={iconPaths[s.icon] ?? ""}
              />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>
