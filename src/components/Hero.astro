---
/**
 * Hero — al-folio "about page" header. Avatar on the right, identity block
 * on the left.  On mobile the avatar drops above the text and centres.
 */
import { site } from "../data/site";
import AvatarSvg from "./AvatarSvg.astro";

const githubHandle = site.github.replace(/^https?:\/\/github\.com\//, "");
---

<section
  id="about"
  class="fade-in mt-10 grid gap-10 md:grid-cols-[1fr_240px] md:items-start"
>
  <div class="min-w-0 order-2 md:order-1">
    <h1 class="name">
      <span lang="zh-Hans">{site.name.zh}</span>
      <span class="ml-2 text-[0.6em] align-baseline" style="color: var(--fg-subtle); font-family: var(--font-sans); font-weight: 400;">
        ({site.name.enFull})
      </span>
    </h1>

    <p class="subtitle mt-3" set:html={site.subtitle} />

    <div class="mt-6 space-y-4 text-[15.5px] leading-[1.75]" style="color: var(--fg);">
      <p set:html={site.bioEn} />
      <p lang="zh-Hans" set:html={site.bioZh} />
    </div>

    <div class="contact-row" aria-label="Contact">
      <a href={`mailto:${site.email}`} aria-label="Email" title={site.email}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
      </a>
      <a href={site.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" title={`github.com/${githubHandle}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
          <path d="M9 18c-4.51 2-5-2-7-2" />
        </svg>
      </a>
      {site.scholar && (
        <a href={site.scholar} target="_blank" rel="noopener noreferrer" aria-label="Google Scholar" title="Google Scholar">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" />
            <path d="M22 10v6" />
            <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5" />
          </svg>
        </a>
      )}
      {site.orcid && (
        <a href={site.orcid} target="_blank" rel="noopener noreferrer" aria-label="ORCID" title="ORCID">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <path d="M9 9v8" /><path d="M9 7h.01" />
            <path d="M13 9h2.5a3.5 3.5 0 0 1 0 7H13z" />
          </svg>
        </a>
      )}
    </div>
  </div>

  <div class="order-1 md:order-2 flex md:justify-end">
    <div class="avatar" aria-hidden="true">
      <AvatarSvg />
    </div>
  </div>
</section>
